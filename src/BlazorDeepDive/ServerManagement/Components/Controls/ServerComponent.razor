    <div data-name="@server.Name" data-status="Server is @(server.IsOnline ? "online" : "offline")"
         style="color: @(server.IsOnline ? "green" : "red")">
        @server.Name is located in @server.City that is @(server.IsOnline ? "online" : "offline")
        &nbsp;
        <button type="submit" class="btn btn-primary" @onclick="ChangeStatus">Turn On/Off</button>
    </div>
}



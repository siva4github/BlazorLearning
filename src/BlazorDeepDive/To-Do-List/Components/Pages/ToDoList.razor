@page "/todolist"
@using To_Do_List.Models
@rendermode InteractiveServer

<h3>To Do List</h3>
<br />

<button type="button" class="btn btn-primary" @onclick="AddTask">Add Task</button>
<br />
<br />
@if (_items == null || _items.Count == 0)
{
    <p>No items in the list.</p>
}
else
{
    <ul class="list-unstyled">
       @foreach (var item in _items)
       {
           <li @key="item.Id">
               <div class="row mb-1">
                   <div class="col-1" style="width:30px">
                        <input type="checkbox" style="vertical-align:middle" @bind-value="item.IsCompleted" checked="@item.IsCompleted" />
                   </div>
                  <div class="col" style="width:100px">
                        @if (item.IsCompleted)
                        {
                            <input type="text" style="vertical-align:middle" @bind-value="item.Name"
                                   class="form-control border-0 text-decoration-line-through" disabled />
                        }
                        else
                        {
                            <input type="text" style="vertical-align:middle" @bind-value="item.Name" class="form-control border-0" />
                        }
                        
                  </div>
                   <div class="col">
                       @if(item.IsCompleted)
                        {
                            <text>Completed at:  @item.DateCompleted.ToLongDateString()</text>
                        }
                    </div>

               </div>
           </li>
        }
    </ul>
}
@code {

    private List<ToDoItem> _items = ToDoItemRepository.GetToDoItems();

    private void AddTask()
    {
        var newItem = new ToDoItem
        {
            Name = "New Task"
        };

        ToDoItemRepository.AddToDoItem(newItem);

        _items = ToDoItemRepository.GetToDoItems();
    }
}
